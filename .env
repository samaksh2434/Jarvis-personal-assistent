# ─────────────────────────────────────────────
#  JARVIS  —  Environment Configuration
# ─────────────────────────────────────────────
#  Copy this to .env and fill in your values

# ── AI MODEL ──────────────────────────────────
# OpenRouter (recommended — 100+ models, free tier)
#OPENROUTER_API_KEY=openRouter key here

# Other options (uncomment the one you want):
#GROQ_API_KEY=groq api key
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=Gimini key here

# Override model name (optional — auto-selected if blank)
# AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── VOICE (ElevenLabs — best human-like male voice) ──
ELEVENLABS_API_KEY= Eleven lab api key
# Daniel = British male, calm, closest to movie JARVIS
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# ── PERSONAL ──────────────────────────────────
USER_NAME=sir
