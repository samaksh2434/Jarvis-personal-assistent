# ─────────────────────────────────────────────────────────────────
#  JARVIS .env — Add your API keys here
#  JARVIS tries them in order: Groq → OpenRouter → Gemini → OpenAI → Anthropic → Ollama
#  Add as many as you want — it auto-switches if one fails
# ─────────────────────────────────────────────────────────────────

# ── FAST FREE (Groq — recommended, fastest free tier) ────────────
 GROQ_API_KEY= Insert Key Here

# ── FREE MODELS (OpenRouter) ─────────────────────────────────────
OPENROUTER_API_KEY=Insert Key Here

# ── GEMINI (Google — free tier) ──────────────────────────────────
 GEMINI_API_KEY=Insert Key Here
# NOTE: use model gemini-1.5-flash 
# ── OPENAI ───────────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_key_here

# ── ANTHROPIC ────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── OLLAMA (offline fallback — auto-used if all online APIs fail) ─
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
# Make sure Ollama is running: ollama serve

# ── VOICE (ElevenLabs — human male voice) ────────────────────────
ELEVENLABS_API_KEY=Insert Key Here
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# ── FORCE A SPECIFIC MODEL (optional) ────────────────────────────
# AI_MODEL=llama-3.3-70b-versatile

# ── PERSONAL ─────────────────────────────────────────────────────
USER_NAME=sir
