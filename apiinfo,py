import requests

def get_api_info(api_url, api_key):
    headers = {
        'Authorization': f'Bearer {api_key}'
    }
    response = requests.get(api_url, headers=headers)
    if response.status_code == 200:
        api_info = response.json()
        return api_info
    else:
        return None

